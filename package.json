{
  "name": "opencode-review",
  "version": "0.2.0",
  "description": "A review agent plugin for OpenCode CLI - structured code review with configurable dimensions",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit --allowImportingTsExtensions",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "verify": "pnpm typecheck && pnpm lint && pnpm build && pnpm test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "review",
    "code-review",
    "agent"
  ],
  "author": "sun-praise",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@opencode-ai/plugin": "^1.17.13",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
