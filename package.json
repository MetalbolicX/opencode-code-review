{
  "name": "opencode-code-review",
  "version": "1.0.6",
  "description": "A review agent plugin for OpenCode CLI - structured code review with configurable dimensions",
  "type": "module",
  "main": "dist/plugin.mjs",
  "oc-plugin": [
    "server"
  ],
  "exports": {
    ".": "./dist/plugin.mjs",
    "./server": "./dist/plugin.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MetalbolicX/opencode-code-review.git"
  },
  "bin": {
    "ocr": "./dist/cli.mjs"
  },
  "files": [
    "dist/cli.mjs",
    "dist/cli.mjs.map",
    "dist/plugin.mjs",
    "dist/plugin.mjs.map",
    "dist/rolldown-runtime-*.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && rolldown -c && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit --allowImportingTsExtensions",
    "lint": "biome check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm typecheck && pnpm lint && pnpm build && pnpm test && pnpm verify:install",
    "verify:install": "node scripts/verify-install.mjs",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "review",
    "code-review",
    "agent"
  ],
  "author": "sun-praise",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@opencode-ai/plugin": "^1.17.13",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "rolldown": "^1.1.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
