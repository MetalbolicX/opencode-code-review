{
  "name": "opencode-code-review",
  "version": "1.0.0",
  "description": "A review agent plugin for OpenCode CLI - structured code review with configurable dimensions",
  "type": "module",
  "main": "dist/plugin.mjs",
  "oc-plugin": [
    "server"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MetalbolicX/opencode-code-review.git"
  },
  "bin": {
    "ocr": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && rolldown -c && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit --allowImportingTsExtensions",
    "lint": "biome check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm typecheck && pnpm lint && pnpm build && pnpm test",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "review",
    "code-review",
    "agent"
  ],
  "author": "sun-praise",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@opencode-ai/plugin": "^1.17.13",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "rolldown": "^1.1.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "packageManager": "pnpm@11.13.1+sha512.b2fc7683b8a6525414e7d13e1ba28caaddde96bf66ec540bfaeb7e702b81f3e0be4d1f295edf7f9fe0396740a8dce4509c582ddf79891f4543fea32d37645f25"
}
