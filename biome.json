{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "off" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "bracketSpacing": true
    }
  },
  "overrides": [
    {
      "includes": ["**/src/**"],
      "linter": {
        "rules": {
          "preset": "recommended"
        }
      }
    }
  ],
  "files": {
    "ignoreUnknown": true
  }
}
